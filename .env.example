# =========================================================================
# Serasi Nusa Redev - Environment Variables
# Salin file ini menjadi `.env.local` lalu isi nilainya.
# Di Vercel, set variabel yang sama lewat: Project > Settings > Environment Variables.
# =========================================================================

# Connection string MongoDB Atlas.
# Ambil dari Atlas: Cluster > Connect > Drivers.
# Sertakan nama database di path URL (mis. .../serasinusa?retryWrites=true&w=majority).
MONGODB_URI="mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/serasinusa?retryWrites=true&w=majority&appName=Cluster0"

# Nama database (fallback bila tidak disertakan di MONGODB_URI).
MONGODB_DB="serasinusa"

# Token rahasia untuk melindungi endpoint tulis (create/update/delete) artикel.
# Kirim sebagai header `x-admin-token` saat memanggil API /api/posts.
# Buat string acak panjang, mis. dengan: openssl rand -hex 32
ADMIN_TOKEN="ganti-dengan-string-acak-yang-panjang"
